{
    "name": "gungraun-action",
    "license": "MIT",
    "version": "0.1.0",
    "author": {
        "name": "gamma0987",
        "email": "gamma0987@posteo.de"
    },
    "description": "GitHub Action to setup Gungraun and install gungraun-runner and valgrind",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/gungraun/gungraun-action.git"
    },
    "keywords": [
        "actions",
        "gungraun",
        "valgrind",
        "setup"
    ],
    "engines": {
        "node": ">=22.0.0"
    },
    "main": "dist/index.js",
    "scripts": {
        "build": "ncc build src/main.ts -o dist --source-map",
        "build:check": "npm run build && git diff --exit-code --quiet dist/",
        "bundle": "npm run format:write && npm run package",
        "check": "tsc --noEmit",
        "format:check": "prettier --check .",
        "format:write": "prettier --write .",
        "lint": "eslint .",
        "package": "rimraf ./dist && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
        "prepare": "simple-git-hooks",
        "test": "NODE_NO_WARNINGS=1 jest",
        "test:coverage": "jest --coverage"
    },
    "simple-git-hooks": {
        "pre-commit": "npm run format:write && npm run lint && npm run build:check",
        "pre-push": "npm run format:write && npm run lint && npm test && npm run build"
    },
    "dependencies": {
        "@actions/core": "^1.10.1",
        "@actions/exec": "^1.1.1",
        "@actions/github": "^6.0.0",
        "@actions/io": "^1.1.3",
        "@actions/tool-cache": "^2.0.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^20.11.0",
        "@vercel/ncc": "^0.38.3",
        "eslint": "^9.39.4",
        "jest": "^30.3.0",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "rollup": "^4.60.1",
        "simple-git-hooks": "^2.13.1",
        "ts-jest": "^29.4.9",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.58.2"
    }
}
