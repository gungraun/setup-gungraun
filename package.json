{
    "name": "gungraun-action",
    "version": "0.1.0",
    "description": "GitHub Action to install gungraun-runner and valgrind",
    "main": "dist/index.js",
    "scripts": {
        "build": "ncc build src/main.ts -o dist --source-map",
