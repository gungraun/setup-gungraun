{
    "name": "setup-gungraun",
    "license": "MIT",
    "version": "1.0.2",
    "author": {
        "name": "gamma0987",
        "email": "gamma0987@posteo.de"
    },
    "description": "GitHub Action to setup Gungraun and install gungraun-runner and Valgrind",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/gungraun/setup-gungraun.git"
    },
    "keywords": [
        "actions",
        "gungraun",
        "valgrind",
        "setup"
    ],
    "engines": {
        "node": ">=24.0.0"
    },
    "main": "dist/index.js",
    "scripts": {
        "build": "ncc build src/main.ts -o dist",
        "build:check": "npm run build && git diff --exit-code --quiet dist/",
        "check": "tsc --noEmit -p tsconfig.build.json",
        "format:check": "prettier --check .",
        "format:write": "prettier --write .",
        "lint": "eslint .",
        "prepare": "simple-git-hooks",
        "test": "NODE_NO_WARNINGS=1 jest",
        "test:coverage": "jest --coverage"
    },
    "simple-git-hooks": {
        "pre-commit": "npm run format:write && npm run lint && npm run build:check",
        "pre-push": "npm run format:write && npm run lint && npm test && npm run build && npm install"
    },
    "dependencies": {
        "@actions/core": "^2.0.0",
        "@actions/exec": "^2.0.0",
        "@actions/github": "^8.0.0",
        "@actions/io": "^2.0.0",
        "@actions/tool-cache": "^3.0.0",
        "shell-quote": "^1.8.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.0.0",
        "@types/shell-quote": "^1.7.5",
        "@vercel/ncc": "^0.38.3",
        "eslint": "^10.0.0",
        "jest": "^30.3.0",
        "prettier": "^3.8.3",
        "simple-git-hooks": "^2.13.1",
        "ts-jest": "^29.4.9",
        "typescript": "^6.0.0",
        "typescript-eslint": "^8.58.2"
    }
}
