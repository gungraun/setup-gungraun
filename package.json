        "@actions/github": "^6.0.0",
        "@actions/io": "^1.1.3",
        "@actions/tool-cache": "^2.0.1"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^20.11.0",
        "@vercel/ncc": "^0.38.3",
        "jest": "^30.3.0",
        "ts-jest": "^29.4.9",
        "typescript": "^5.3.3"
    }
